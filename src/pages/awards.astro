---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SideNav from '../components/SideNav.astro';

// ─────────────────────────────────────────────────────────────────────────────
// Award data. Edit these six entries — or replace the cover images.
//   cover : path to the picture (drop your own into /public/images/awards/ and
//           point here; a .jpg/.png/.svg all work). The included award-N.svg
//           files are just themed placeholders.
//   title : shown under the cover and again at the top of the expanded view.
//   blurb : the "more information" revealed when a card is opened.
// The pre-filled text is pulled from the About page — tweak freely.
// ─────────────────────────────────────────────────────────────────────────────
const awards = [
  {
    title: "NASA Space Camp — The Right Stuff Award",
    cover: "/images/awards/award-1.svg",
    alt: "Cover image for the NASA Space Camp Right Stuff Award",
    blurb:
      "Trained as an astronaut at NASA's Space Camp and came home with the Right Stuff Award — recognition for leadership and teamwork across the programme's simulated missions.",
  },
  {
    title: "SciFest Technology Category & EirGrid Award",
    cover: "/images/awards/award-2.svg",
    alt: "Cover image for the SciFest Technology Category and EirGrid Award",
    blurb:
      "With a four-person team, won SciFest's Technology Category and the EirGrid Award for a carbon-capture filter that used CAD and 3D printing to cut CO₂ from car exhausts.",
  },
  {
    title: "European Girls' Mathematical Olympiad",
    cover: "/images/awards/award-3.svg",
    alt: "Cover image for the European Girls' Mathematical Olympiad",
    blurb:
      "Competed in the European Girls' Mathematical Olympiad, placing in the top 10 in Ireland.",
  },
  {
    title: "National Programming Olympiad — Finalist",
    cover: "/images/awards/award-4.svg",
    alt: "Cover image for the national Programming Olympiad finals",
    blurb:
      "Reached the finals of the national Programming Olympiad, solving timed algorithmic problems against the strongest young programmers in the country.",
  },
  {
    title: "Lynra — Patch Accelerator Demo Day",
    cover: "/images/awards/award-5.svg",
    alt: "Cover image for Lynra at the Patch Summer Accelerator Demo Day",
    blurb:
      "Co-founded Lynra at Dublin's Patch Summer Accelerator and presented the autonomous, tree-injecting rover live at Demo Day to an audience of 300+ investors, founders, and industry leaders.",
  },
  {
    title: "SÓShielta — Hack Europe",
    cover: "/images/awards/award-6.svg",
    alt: "Cover image for SÓShielta, built at Hack Europe",
    blurb:
      "Built SÓShielta with a four-person team at Hack Europe, designing and shipping a working project inside the hackathon's tight time limit.",
  },
];
---

<BaseLayout title="Awards and Achievements">
  <SiteHeader />
  <SideNav />

  <main class="awards-main">
    <h1 class="awards-title">Awards &amp; Achievements</h1>
    <p class="awards-hint">Tap a cover to read the story behind it.</p>

    <ul class="award-grid">
      {awards.map((award, i) => (
        <li class="award-cell">
          <button
            type="button"
            class="award-card"
            data-index={i}
            data-title={award.title}
            data-cover={award.cover}
            data-alt={award.alt}
            data-blurb={award.blurb}
            aria-haspopup="dialog"
          >
            <span class="award-cover">
              <img src={award.cover} alt={award.alt} loading="lazy" width="800" height="600" />
              <span class="award-expand" aria-hidden="true">+</span>
            </span>
            <span class="award-title">{award.title}</span>
          </button>
        </li>
      ))}
    </ul>
  </main>

  <!-- Expanded view (one dialog, reused for every card) -->
  <div class="award-modal" id="award-modal" role="dialog" aria-modal="true" aria-labelledby="award-modal-title" hidden>
    <div class="award-modal__backdrop" data-close></div>
    <div class="award-modal__panel" role="document">
      <button type="button" class="award-modal__close" data-close aria-label="Close">&times;</button>
      <div class="award-modal__media">
        <img id="award-modal-img" src="" alt="" width="800" height="600" />
      </div>
      <div class="award-modal__body">
        <h2 class="award-modal__title" id="award-modal-title"></h2>
        <p class="award-modal__text" id="award-modal-text"></p>
      </div>
    </div>
  </div>

  <SiteFooter />
</BaseLayout>

<style>
  /* ── Page shell ────────────────────────────────────────────────────── */
  .awards-main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-6) var(--space-16);
  }

  .awards-title {
    font-family: 'Press Start 2P', cursive;
    font-size: calc(var(--text-2xl) * 1.2);
    font-weight: 400;
    color: #f699cd;
    text-align: center;
    line-height: 1.4;
    margin-top: var(--space-12);
    -webkit-text-stroke: 2px #000000;
    paint-order: stroke fill;
  }

  .awards-hint {
    margin-top: var(--space-4);
    margin-bottom: var(--space-12);
    color: var(--color-brand);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
    opacity: 0.85;
  }

  /* ── Grid of six ───────────────────────────────────────────────────── */
  .award-grid {
    list-style: none;
    width: 100%;
    max-width: 1080px;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 600px) {
    .award-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .award-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .award-cell { display: flex; }

  /* ── Card ──────────────────────────────────────────────────────────── */
  .award-card {
    /* button reset */
    appearance: none;
    border: none;
    background: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: inherit;
    text-align: left;
    cursor: pointer;

    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .award-cover {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 3px solid #FF69B4;
    background-color: #000000;
    transition:
      transform 0.35s cubic-bezier(.22,.61,.36,1),
      box-shadow 0.35s ease;
  }

  .award-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(.22,.61,.36,1);
  }

  /* The "expand" cue — echoes the site's images-expand-to-fill motif. */
  .award-expand {
    position: absolute;
    right: var(--space-3);
    bottom: var(--space-3);
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.8rem;
    line-height: 1;
    color: #000000;
    background-color: #FF69B4;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .award-title {
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: var(--text-lg);
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: var(--color-brand);
  }

  /* Hover / focus: lift, glow, nudge the cover image, reveal the cue. */
  .award-card:hover .award-cover,
  .award-card:focus-visible .award-cover {
    transform: translateY(-6px);
    box-shadow: 0 12px 34px rgba(255, 105, 180, 0.45);
  }

  .award-card:hover .award-cover img,
  .award-card:focus-visible .award-cover img {
    transform: scale(1.06);
  }

  .award-card:hover .award-expand,
  .award-card:focus-visible .award-expand {
    opacity: 1;
    transform: scale(1);
  }

  .award-card:focus-visible .award-cover {
    outline: 2px solid #FF69B4;
    outline-offset: 4px;
  }

  .award-card:focus { outline: none; }

  /* ── Expanded modal ────────────────────────────────────────────────── */
  .award-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .award-modal[hidden] { display: none; }

  .award-modal__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.82);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .award-modal__panel {
    position: relative;
    z-index: 1;
    width: min(880px, 100%);
    max-height: 90svh;
    overflow-y: auto;
    background-color: #000000;
    border: 3px solid #FF69B4;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: scale(0.92);
    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(.22,.61,.36,1);
  }

  /* open state (toggled from script) */
  .award-modal.is-open .award-modal__backdrop { opacity: 1; }
  .award-modal.is-open .award-modal__panel { opacity: 1; transform: scale(1); }

  .award-modal__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    line-height: 1;
    color: #000000;
    background-color: #FF69B4;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .award-modal__close:hover { background-color: var(--color-accent-light); }

  .award-modal__close:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 2px;
  }

  .award-modal__media {
    width: 100%;
    background-color: #000000;
  }

  .award-modal__media img {
    width: 100%;
    max-height: 52svh;
    object-fit: contain;
    display: block;
  }

  .award-modal__body {
    background-color: #FF69B4;
    color: #FFFFFF;
    padding: var(--space-8);
  }

  .award-modal__title {
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .award-modal__text {
    font-size: var(--text-base);
    line-height: 1.8;
  }

  /* ── Light-mode overrides (site toggles [data-theme="light"]) ──────── */
  :global([data-theme="light"]) .awards-title { color: #f699cd; }

  :global([data-theme="light"]) .award-cover { background-color: #ffffff; }

  :global([data-theme="light"]) .award-modal__panel {
    background-color: #ffffff;
  }

  :global([data-theme="light"]) .award-modal__media { background-color: #ffffff; }

  :global([data-theme="light"]) .award-modal__body {
    background-color: #f699cd;
    color: #000000;
  }

  /* ── Reduced motion: keep it still ─────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .award-cover,
    .award-cover img,
    .award-expand,
    .award-modal__backdrop,
    .award-modal__panel {
      transition: none;
    }

    .award-card:hover .award-cover,
    .award-card:focus-visible .award-cover { transform: none; }

    .award-card:hover .award-cover img,
    .award-card:focus-visible .award-cover img { transform: none; }
  }
</style>

<script>
  // Reuse one dialog for all cards: populate it from the clicked card's data,
  // animate it open, and restore focus to that card when it closes.
  const modal = document.getElementById('award-modal') as HTMLElement | null;
  const modalImg = document.getElementById('award-modal-img') as HTMLImageElement | null;
  const modalTitle = document.getElementById('award-modal-title');
  const modalText = document.getElementById('award-modal-text');
  const cards = Array.from(document.querySelectorAll<HTMLButtonElement>('.award-card'));

  if (modal && modalImg && modalTitle && modalText) {
    let lastFocused: HTMLElement | null = null;

    const open = (card: HTMLButtonElement) => {
      lastFocused = card;
      modalImg.src = card.dataset.cover ?? '';
      modalImg.alt = card.dataset.alt ?? '';
      modalTitle.textContent = card.dataset.title ?? '';
      modalText.textContent = card.dataset.blurb ?? '';

      modal.hidden = false;
      document.documentElement.style.overflow = 'hidden'; // lock background scroll
      // next frame so the transition runs from the hidden state
      requestAnimationFrame(() => modal.classList.add('is-open'));

      const closeBtn = modal.querySelector<HTMLButtonElement>('.award-modal__close');
      closeBtn?.focus();
    };

    const close = () => {
      modal.classList.remove('is-open');
      document.documentElement.style.overflow = '';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finish = () => { modal.hidden = true; };
      if (reduce) {
        finish();
      } else {
        modal.addEventListener('transitionend', finish, { once: true });
        setTimeout(finish, 400); // fallback if transitionend doesn't fire
      }

      lastFocused?.focus();
      lastFocused = null;
    };

    cards.forEach((card) => card.addEventListener('click', () => open(card)));

    modal.querySelectorAll('[data-close]').forEach((el) =>
      el.addEventListener('click', close)
    );

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }
</script>
