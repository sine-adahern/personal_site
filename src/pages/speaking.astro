---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SideNav from '../components/SideNav.astro';
---

<BaseLayout title="Speaking & Debating">
  <SiteHeader />
  <SideNav />
  <main>
    <h1 class="speaking-title">Speaking &amp; Debating</h1>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /*
    Page-specific background. Overrides the global --color-bg-gradient just for
    this page (this style block is only ever loaded on /speaking). A gentle
    top-anchored radial glow using the site's existing pink accents keeps the
    effect very subtle: colour concentrates at the top and fades to the base.

    Dark (default): dark-pink (#E0429A accent) -> black
    Light:          light-pink (#FFB3D9 accent) -> white
  */
  :global(body) {
    background-image: radial-gradient(
      ellipse 90% 55% at 50% 0%,
      #E0429A 0%,
      #000000 55%
    );
  }

  :global([data-theme="light"] body) {
    background-image: radial-gradient(
      ellipse 90% 55% at 50% 0%,
      #FFB3D9 0%,
      #ffffff 55%
    );
  }

  /*
    Let the gradient run all the way to the top of the page. The shared header
    has an opaque background by default; making it transparent here lets the
    body gradient show through behind it. The "Sinéad Ahern" title keeps its
    own colour + black stroke, so it stays fully visible (not transparent).
  */
  :global(.site-header) {
    /* !important beats the header component's own more specific scoped rule
       (.site-header[data-astro-cid-...]) which sets an opaque background. */
    background-color: transparent !important;
  }

  /*
    Page heading in the same pixel style as the other pages' titles
    (.awards-title / .portfolio-title): Press Start 2P, centred, with the
    black text-stroke. Brand pink keeps it in step with this page's theme.
  */
  .speaking-title {
    font-family: 'Press Start 2P', cursive;
    font-size: calc(var(--text-2xl) * 1.2);
    font-weight: 400;
    color: var(--color-brand);
    text-align: center;
    line-height: 1.4;
    margin-top: var(--space-12);
    -webkit-text-stroke: 2px #000000;
    paint-order: stroke fill;
  }
</style>
