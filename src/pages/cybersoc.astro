---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SideNav from '../components/SideNav.astro';

// Reloading the page ALWAYS replays the intro. This flag only affects in-site
// navigation: true = play once per browser session when moving between pages;
// false = replay on every navigation to this page as well.
const BOOT_ONCE_PER_SESSION = true;
---

<BaseLayout title="Cyber SOC">
  <!-- ── Boot intro overlay ─────────────────────────────────────────────
       Sits on top of the real page. A kernel-style boot log prints, settles
       into a fake terminal, and on ENTER (or tap) "runs" a command before
       dissolving to reveal <main>. Follows the site's light/dark theme. -->
  <div
    id="boot-screen"
    class="boot-screen"
    data-once={BOOT_ONCE_PER_SESSION ? 'true' : 'false'}
    role="dialog"
    aria-label="System boot sequence"
  >
    <button id="boot-skip" class="boot-skip" type="button">skip &#9656;</button>
    <div class="boot-inner">
      <pre id="boot-log" class="boot-log" aria-hidden="true"></pre>
      <div id="boot-prompt" class="boot-prompt" hidden>
        <span class="prompt-line">
          <span class="prompt-user">visitor@cybersoc</span><span class="prompt-sym">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span>
          <span id="boot-cmd" class="boot-cmd"></span><span id="boot-cursor" class="cursor">&#9608;</span>
        </span>
        <pre id="boot-out" class="boot-out" aria-hidden="true"></pre>
        <button id="boot-enter" class="boot-enter" type="button" hidden>&#9654; press ENTER</button>
      </div>
    </div>
  </div>

  <!-- Runs before the page paints so the overlay never flashes: decide up front
       whether to show the intro. A reload always shows it; otherwise show unless
       we've already booted this session. Reduced motion always skips. -->
  <script is:inline define:vars={{ once: BOOT_ONCE_PER_SESSION }}>
    (function () {
      var el = document.getElementById('boot-screen');
      if (!el) return;

      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var reload = false;
      try {
        var nav = performance.getEntriesByType('navigation')[0];
        if (nav && nav.type) reload = nav.type === 'reload';
        else if (performance.navigation) reload = performance.navigation.type === 1;
      } catch (e) {}

      var seen = once && sessionStorage.getItem('cybersoc:booted') === '1';

      if (reduce || (seen && !reload)) {
        el.setAttribute('hidden', '');
      } else {
        document.documentElement.classList.add('boot-active');
      }
    })();
  </script>

  <SiteHeader />
  <SideNav />
  <main class="cybersoc-main">
    <h1 class="cybersoc-title">
      MTU Cybersecurity Society
      <span class="cybersoc-role">(Re)founder and Chairperson</span>
    </h1>

    <section class="about-box" aria-labelledby="how-it-came-about">
      <h2 class="box-heading" id="how-it-came-about">How It Came About</h2>

      <p>When I started at MTU, the Cybersecurity Society technically already existed — but only on paper. Its previous board had finished their masters and moved on without leaving a legacy behind them: no handover, no committee, no plan for who came next. The society had been dormant for close to a year.</p>

      <p>Cybersecurity is my degree and my genuine interest, and it seemed like a waste that a university with MTU's cyber credentials didn't have a student community to match. So alongside a group of my peers, I set out to bring it back.</p>

      <p>Rebuilding it meant starting from the ground up:</p>

      <ul class="rebuild-list">
        <li><strong>Learning from the people who came before.</strong> We tracked down and met with former members to understand what the society had been, what had worked, and what had caused it to stall — so we wouldn't repeat the same mistake of building something that couldn't outlive us.</li>
        <li><strong>Getting the university behind us.</strong> We liaised with MTU faculty and the Head of the Computer Science Department to re-establish the society properly and make sure it had institutional support.</li>
        <li><strong>Putting a real committee in place.</strong> We held an AGM, elected a full board, and gave every role a clear owner.</li>
        <li><strong>Starting to run events again.</strong> CTFs, industry talks, hackathons, and a space for people to actually turn up to.</li>
      </ul>

      <p>I was elected Chairperson, and within a few months the society went from inactive to sending students onto panels at a global telecoms conference.</p>

      <p>MTU is one of Ireland's leading cybersecurity hubs — home to Cork's Nimbus Research Centre, its national Cyber Range and prototyping labs, dedicated cyber degrees, and the €7M Cyber Innovate programme. The society exists to bring that world within reach of students: hands-on skills, CTFs, and real connections to Ireland's cyber industry.</p>

      <p>At its heart, though, it's about people. It's a space where students connect, collaborate, and grow together, with no experience required — from complete beginners to seasoned hackers. A community built on curiosity, teamwork, and a shared drive to learn.</p>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  // ── Boot intro logic ────────────────────────────────────────────────
  const overlay = document.getElementById('boot-screen');

  // If the pre-paint inline script hid the overlay (repeat visit / reduced
  // motion), there's nothing to animate — the real page is already showing.
  if (overlay && !overlay.hasAttribute('hidden')) {
    const logEl    = document.getElementById('boot-log') as HTMLElement;
    const promptEl = document.getElementById('boot-prompt') as HTMLElement;
    const cmdEl    = document.getElementById('boot-cmd') as HTMLElement;
    const cursorEl = document.getElementById('boot-cursor') as HTMLElement;
    const outEl    = document.getElementById('boot-out') as HTMLElement;
    const enterEl  = document.getElementById('boot-enter') as HTMLButtonElement;
    const skipEl   = document.getElementById('boot-skip') as HTMLButtonElement;

    const oncePerSession = overlay.dataset.once === 'true';

    // Kernel-style boot log. Lines starting with a "[  n.nnn ]" timestamp are
    // dimmed; "[  OK  ]" tags go green. Blank strings render as spacer lines.
    const BOOT_LINES = [
      '[    0.000000] Linux version 6.8.0-cyber (root@mtu-cybersoc) #1 SMP PREEMPT',
      '[    0.000000] Command line: BOOT_IMAGE=/boot/vmlinuz-cyber ro quiet splash',
      '[    0.000031] KERNEL supported cpus: caffeine curiosity chaos',
      '[    0.004212] x86/fpu: Supporting XSAVE feature 0x001: "curiosity register"',
      '[    0.014550] ACPI: Early table checksum verification disabled',
      '[    0.221004] smpboot: CPU0: online',
      '[    0.331200] pci 0000:00:02.0: [8086] serial bus controller',
      '[    0.402118] usb 1-1: new high-speed USB device number 2',
      '[    0.402990] usb 1-1: product: USB Rubber Ducky (blocked)',
      '[    0.511003] random: crng init done',
      '[    0.688210] EXT4-fs (sda1): mounted filesystem with ordered data mode',
      '[    0.712004] systemd[1]: Detected architecture x86-64.',
      '[    0.740550] systemd[1]: Hostname set to <mtu-cybersoc>.',
      '',
      '[  OK  ] Reached target Cryptography Subsystem.',
      '[  OK  ] Started Firewall (nftables).',
      '[  OK  ] Started Intrusion Detection Daemon.',
      '[  OK  ] Mounted /home/members.',
      '[  OK  ] Started Coffee Supply Monitor.',
      '[  OK  ] Reached target Capture The Flag.',
      '[  OK  ] Started Weekly Meetup Scheduler.',
      '[  OK  ] Finished Loading Society Roster.',
      '[  OK  ] Reached target Multi-User System.',
      '',
      'MTU CyberSoc 6.8.0-cyber tty1',
      '',
    ];

    const COMMAND = 'python3 cybersoc.py';

    // Output "printed" after the command runs, then the page is revealed.
    const OUT_LINES: { text: string; cls: string }[] = [
      { text: '',                                                    cls: '' },
      { text: '[*] initialising cybersoc.py',                        cls: 'info' },
      { text: '[*] connecting to Munster Technological University',  cls: 'info' },
      { text: '[*] decrypting member roster ............ done',      cls: 'info' },
      { text: '[+] access granted \u2014 launching interface',       cls: 'ok'   },
    ];

    let phase: 'log' | 'prompt' | 'running' | 'done' = 'log';
    let enterReady = false;
    let logIndex = 0;
    let timer: number | undefined;

    const esc = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    function renderLine(raw: string): string {
      if (raw === '') return '\u00a0';
      const e = esc(raw);
      if (raw.startsWith('[  OK  ]')) {
        return '<span class="ok">[  OK  ]</span>' + e.slice('[  OK  ]'.length);
      }
      if (/^\[\s*\d/.test(raw)) return '<span class="dim">' + e + '</span>';
      return e;
    }

    function appendLine(raw: string) {
      const div = document.createElement('div');
      div.className = 'ln';
      div.innerHTML = renderLine(raw);
      logEl.appendChild(div);
      logEl.scrollTop = logEl.scrollHeight;
    }

    // ── Phase 1: print the boot log ───────────────────────────────────
    function stepLog() {
      if (logIndex >= BOOT_LINES.length) {
        showPrompt();
        return;
      }
      appendLine(BOOT_LINES[logIndex]);
      logIndex++;
      const jitter = 20 + Math.random() * 45; // fast, with a little variation
      timer = window.setTimeout(stepLog, jitter);
    }

    function flushLog() {
      if (timer) clearTimeout(timer);
      while (logIndex < BOOT_LINES.length) {
        appendLine(BOOT_LINES[logIndex]);
        logIndex++;
      }
      showPrompt();
    }

    // ── Phase 2: the terminal prompt + auto-typed command ─────────────
    function showPrompt() {
      if (phase !== 'log') return;
      phase = 'prompt';
      promptEl.hidden = false;
      logEl.scrollTop = logEl.scrollHeight;

      let ci = 0;
      function typeCmd() {
        if (ci <= COMMAND.length) {
          cmdEl.textContent = COMMAND.slice(0, ci);
          ci++;
          window.setTimeout(typeCmd, 45 + Math.random() * 40);
        } else {
          enterReady = true;
          enterEl.hidden = false;
          try { enterEl.focus({ preventScroll: true }); } catch (_) {}
        }
      }
      typeCmd();
    }

    // ── Phase 3: "run" the command, then reveal the page ──────────────
    function runCommand() {
      if (phase !== 'prompt' || !enterReady) return;
      phase = 'running';
      enterEl.hidden = true;
      cursorEl.style.display = 'none';

      let oi = 0;
      function stepOut() {
        if (oi >= OUT_LINES.length) {
          window.setTimeout(reveal, 480);
          return;
        }
        const { text, cls } = OUT_LINES[oi];
        const div = document.createElement('div');
        div.className = 'ln';
        if (text === '') {
          div.innerHTML = '\u00a0';
        } else if (cls) {
          div.innerHTML = '<span class="out-' + cls + '">' + esc(text) + '</span>';
        } else {
          div.textContent = text;
        }
        outEl.appendChild(div);
        logEl.scrollTop = logEl.scrollHeight;
        oi++;
        window.setTimeout(stepOut, 170 + Math.random() * 120);
      }
      stepOut();
    }

    function reveal() {
      if (phase === 'done') return;
      phase = 'done';
      if (oncePerSession) {
        try { sessionStorage.setItem('cybersoc:booted', '1'); } catch (_) {}
      }
      overlay.classList.add('is-leaving');
      window.setTimeout(() => {
        overlay.setAttribute('hidden', '');
        document.documentElement.classList.remove('boot-active');
      }, 520);
    }

    // ── Input wiring ──────────────────────────────────────────────────
    // ENTER runs the command in the prompt phase, or fast-forwards the log.
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        if (phase === 'log') { e.preventDefault(); flushLog(); }
        else if (phase === 'prompt') { e.preventDefault(); runCommand(); }
      }
    });

    // Tap support (mobile has no ENTER key).
    enterEl.addEventListener('click', runCommand);
    skipEl.addEventListener('click', () => {
      if (phase === 'log') flushLog();
      else if (phase === 'prompt' && enterReady) runCommand();
    });
    // Tapping the log area during boot fast-forwards it.
    logEl.addEventListener('click', () => { if (phase === 'log') flushLog(); });

    stepLog();
  }
</script>

<style>
  /* ── Page content ──────────────────────────────────────────────────── */
  .cybersoc-main {
    max-width: 1020px;
    margin: 0 auto;
    /* Generous horizontal padding keeps the box off the viewport edges. */
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .cybersoc-title {
    font-family: 'Press Start 2P', cursive;
    font-weight: 400;
    font-size: clamp(1.05rem, 4.4vw, 2.1rem);
    line-height: 1.5;
    text-align: center;
    color: #ffe4c4; /* same cream-yellow as the portfolio heading */
    -webkit-text-stroke: 2px #000000;
    paint-order: stroke fill;
    margin: var(--space-8) 0 var(--space-12);
  }

  .cybersoc-role {
    display: block;
    font-size: 0.62em;
    margin-top: 0.9em;
  }

  .about-box {
    max-width: 920px;
    margin: 0 auto;
    background-color: #f699cd; /* light pink */
    color: #000000;
    border: 2px solid #000000;
    border-radius: var(--radius-md);
    /* Roomy interior padding on all sides, scaling down on small screens. */
    padding: clamp(24px, 6vw, 56px);
    font-size: var(--text-base);
    font-weight: 300; /* Lato thin */
    line-height: 1.7;
  }

  .box-heading {
    font-family: 'Press Start 2P', cursive;
    font-weight: 400;
    font-size: clamp(0.8rem, 2.6vw, 1.05rem);
    line-height: 1.7;
    color: #000000;
    margin: 0 0 var(--space-6);
  }

  .about-box p { margin: 0 0 1.1em; }
  .about-box p:last-child { margin-bottom: 0; }

  .rebuild-list {
    list-style: none;
    margin: 0 0 1.1em;
    padding: 0;
    display: grid;
    gap: 0.75em;
  }

  .rebuild-list li {
    position: relative;
    padding-left: 1.5em;
  }

  .rebuild-list li::before {
    content: '\25B8'; /* ▸ terminal-style marker */
    position: absolute;
    left: 0.15em;
    top: 0;
    font-weight: 700;
  }

  /* The boot screen follows the site's light / dark theme through these vars. */
  .boot-screen {
    --boot-bg:     #000000;
    --boot-fg:     #cfcfcf;
    --boot-dim:    #7d7d7d;
    --boot-ok:     #57d977;
    --boot-accent: #FF69B4; /* prompt user, cursor, info lines, ENTER button */
    --boot-path:   #6fb2ff;
    --boot-cmd:    #ffffff;

    position: fixed;
    inset: 0;
    z-index: 9998; /* below the nav-wheel transition cover (9999), above page */
    background: var(--boot-bg);
    color: var(--boot-fg);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
    font-size: clamp(11px, 2.6vw, 14px);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    padding: clamp(14px, 4vw, 30px);
    overflow: hidden;
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  /* Light-theme palette for the terminal. */
  :global([data-theme="light"]) .boot-screen {
    --boot-bg:     #f6f6f3;
    --boot-fg:     #2b2b2b;
    --boot-dim:    #9a9a9a;
    --boot-ok:     #178f43;
    --boot-accent: #C22E7E;
    --boot-path:   #2f6fd0;
    --boot-cmd:    #111111;
  }

  /* Beats the base `display:flex` so the pre-paint hide actually hides it. */
  .boot-screen[hidden] { display: none !important; }

  .boot-screen.is-leaving { opacity: 0; }

  .boot-inner {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .boot-log,
  .boot-out {
    margin: 0;
    font: inherit;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-y: auto;
  }

  .boot-log { flex: 0 1 auto; }
  .boot-log .ln,
  .boot-out .ln { display: block; }

  .boot-log .ok  { color: var(--boot-ok); }
  .boot-log .dim { color: var(--boot-dim); }

  .boot-prompt { margin-top: 0.5em; }

  /* Brand pink on the prompt user ties the terminal back to the site. */
  .prompt-user { color: var(--boot-accent); font-weight: 700; }
  .prompt-sym  { color: var(--boot-fg); }
  .prompt-path { color: var(--boot-path); }
  .boot-cmd    { color: var(--boot-cmd); }

  .cursor {
    color: var(--boot-accent);
    animation: boot-blink 1s steps(1) infinite;
  }
  @keyframes boot-blink { 50% { opacity: 0; } }

  .boot-out { margin-top: 0.25em; }
  .boot-out .out-info { color: var(--boot-accent); }
  .boot-out .out-ok   { color: var(--boot-ok); }

  .boot-enter {
    display: inline-block;
    margin-top: 0.9em;
    background: none;
    border: 1px solid var(--boot-accent);
    color: var(--boot-accent);
    font: inherit;
    letter-spacing: 0.05em;
    padding: 0.4em 0.85em;
    border-radius: 4px;
    cursor: pointer;
    animation: boot-pulse 1.4s ease-in-out infinite;
  }
  .boot-enter:hover,
  .boot-enter:focus-visible {
    background: var(--boot-accent);
    color: var(--boot-bg);
    outline: none;
    animation: none;
  }
  @keyframes boot-pulse { 0%, 100% { opacity: 0.55; } 50% { opacity: 1; } }

  .boot-skip {
    position: absolute;
    top: clamp(10px, 3vw, 20px);
    right: clamp(10px, 3vw, 20px);
    background: none;
    border: none;
    color: var(--boot-dim);
    font: inherit;
    cursor: pointer;
    z-index: 1;
  }
  .boot-skip:hover,
  .boot-skip:focus-visible { color: var(--boot-accent); outline: none; }

  /* Lock scrolling of the page underneath while the intro is up. */
  :global(html.boot-active),
  :global(html.boot-active body) { overflow: hidden; }
</style>
