---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SideNav from '../components/SideNav.astro';

// Caption is the text that types across the image on hover.
// alt is a short description used for screen readers / if an image fails to load.
const photos = [
  { src: '/images/about/photo-1.jpg',  alt: 'reading',       caption: `Reading is my first love. I'll devour any book, from fact to fiction, but my true love is mystery books.` },
  { src: '/images/about/photo-2.jpg',  alt: 'studying',      caption: `While I complain constantly about studying, it's the one that got me 625 points in my leaving cert, and allowed me to maintain a strong 4.0 GPA in college.` },
  { src: '/images/about/photo-3.jpg',  alt: 'piano',         caption: `I've been playing piano since I was 7, though I've never gone past grade 6.` },
  { src: '/images/about/photo-4.jpg',  alt: 'coffee',        caption: `The one thing that gets me through every day. Working as a barista for 4 years certainly didn't help my obsession.` },
  { src: '/images/about/photo-5.jpg',  alt: 'rings',         caption: `Would I even be who I am without my rings? The oldest one in my stack is almost 90 y/o.` },
  { src: '/images/about/photo-6.jpg',  alt: 'food',          caption: `I love to cook and eat what can I say >-<` },
  { src: '/images/about/photo-7.jpg',  alt: 'speaking',      caption: `From model EU councils in my youth to global conferences, I've always loved the chance to share my experiences and thoughts - what can I say, I'm a yapper at heart.` },
  { src: '/images/about/photo-8.jpg',  alt: 'cybersecurity', caption: `My chosen career path and my second love, this is an area I knew I would dedicate my life to since I was 13.` },
  { src: '/images/about/photo-9.jpg',  alt: 'rover',         caption: `Wow what a cool rover! If only there was a whole page dedicated to it on a site somewhere....` },
  { src: '/images/about/photo-10.jpg', alt: 'fit check',     caption: `Okay so I want to be a fashionista, sue me. Not only do I make my own clothes, I also never shut up about it.` },
  { src: '/images/about/photo-11.jpg', alt: 'skiing',        caption: `Definitely my favorite sport.` },
  { src: '/images/about/photo-12.jpg', alt: 'NASA',          caption: `Did I mention the NASA astronaut training I did?` },
  { src: '/images/about/photo-13.jpg', alt: 'nature',        caption: `After all those darn screens sometimes touching grass is sorely needed.` },
  { src: '/images/about/photo-14.jpg', alt: 'Irish',         caption: `mo teanga feinig agus mo teanga is fear` },
  { src: '/images/about/photo-15.jpg', alt: 'gym',           caption: `Is fear an tsláinte ná an táinte - or whatever they say` },
  { src: '/images/about/photo-16.jpg', alt: 'cat',           caption: `My favorite animal and dream pet, this lil guy isn't mine though :(` },
];
---

<BaseLayout title="About Me">
  <SiteHeader />
  <SideNav />
  <main>

    <!-- ── Scrolling circle banner ──────────────────────────────────── -->
    <!-- aria-hidden: same images appear accessibly in the grid below -->
    <section class="banner-scroll" aria-hidden="true">
      <ul class="banner-track">
        {photos.map(photo => (
          <li class="banner-item">
            <img src={photo.src} alt="" class="banner-img" width="160" height="160" />
          </li>
        ))}
        {photos.map(photo => (
          <li class="banner-item">
            <img src={photo.src} alt="" class="banner-img" width="160" height="160" loading="lazy" />
          </li>
        ))}
      </ul>
    </section>

    <!-- ── Pink bio strip ────────────────────────────────────────────── -->
    <section class="bio-strip" aria-label="About me">
      <div class="bio-inner">
        <h2 class="bio-heading">About me</h2>
        <p class="bio-text">
          I'm a Cybersecurity and IT Management student at Munster Technological University, and I currently chair <a href="/cybersoc">MTU's Cybersecurity Society</a>. My interest in security is hands-on: I've shadowed Johnson &amp; Johnson's cybersecurity team watching how threat detection actually works inside a large organisation, and I'm building toward a career in security engineering.
        </p>
        <p class="bio-text">
          I work in Python, C++, JavaScript, and Rust, and I like the kind of problem-solving that rewards patience, a habit I picked up competing in the European Girls' Mathematical Olympiad (top 10 in Ireland) and the national Programming Olympiad finals. I'm happiest when I'm building something real: I co-founded <a href="/patch">Lynra</a> at Dublin's Patch accelerator, training an object-detection model and putting it on a rover that delivers micro-injections to diseased ash trees. Earlier, a four-person team and I won SciFest's Technology Category and the EirGrid Award for a carbon-capture filter that used CAD and 3D printing to cut CO₂ from car exhausts. More recently I built SÓShielta at Hack Europe with a four-person team.
        </p>
        <p class="bio-text">
          Outside the strictly technical stuff, I've trained as an astronaut at <a href="/trips">NASA's Space Camp</a> (and somehow came home with the Right Stuff Award). I read a lot — mystery novels especially — and I make my own clothes. Both scratch the same itch as everything else: at heart I'm a problem-solver, the kind who's just as happy untangling a network connectivity issue as a locked-room murder; figuring out how the pieces fit together to make something that works.
        </p>
        <p class="bio-text">
          I'm always up for interesting projects and conversations — get in touch.
        </p>
      </div>
    </section>

    <!-- ── 3 × 4 photo grid ──────────────────────────────────────────── -->
    <!-- Add real src and caption per photo when content is ready.       -->
    <h2 class="interests-heading">my interests</h2>
    <ul class="photo-grid" aria-label="Photo gallery">
      {photos.map(photo => (
        <li class="photo-item">
          <div class="photo-card" data-caption={photo.caption}>
            <img
              src={photo.src}
              alt={photo.alt}
              class="photo-img"
              loading="lazy"
              width="300"
              height="400"
            />
            <div class="photo-overlay" aria-hidden="true">
              <span class="photo-caption"></span>
            </div>
          </div>
        </li>
      ))}
    </ul>

  </main>
  <SiteFooter />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { TextPlugin } from 'gsap/TextPlugin';

  gsap.registerPlugin(TextPlugin);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Banner scroll
  const bannerTrack = document.querySelector<HTMLElement>('.banner-track');
  if (bannerTrack && !prefersReducedMotion) {
    gsap.to(bannerTrack, {
      xPercent: -50,
      duration: 30,
      ease: 'none',
      repeat: -1,
    });
  }

  document.querySelectorAll<HTMLElement>('.photo-card').forEach(card => {
    const overlay  = card.querySelector<HTMLElement>('.photo-overlay');
    const captionEl = card.querySelector<HTMLElement>('.photo-caption');
    const text = card.dataset.caption ?? '';

    if (!overlay || !captionEl) return;

    let tween: gsap.core.Tween | undefined;

    card.addEventListener('mouseenter', () => {
      tween?.kill();
      if (prefersReducedMotion) {
        gsap.set(overlay, { opacity: 1 });
        if (text) captionEl.textContent = text;
        return;
      }
      gsap.to(overlay, { opacity: 1, duration: 0.2 });
      if (text) {
        tween = gsap.to(captionEl, {
          text,
          duration: Math.max(0.5, text.length * 0.04),
          ease: 'none',
          delay: 0.15,
        });
      }
    });

    card.addEventListener('mouseleave', () => {
      tween?.kill();
      captionEl.textContent = '';
      gsap.to(overlay, { opacity: 0, duration: 0.3 });
    });
  });
</script>

<style>
  main {
    min-height: 100svh;
  }

  /* ── Scrolling circle banner ───────────────────────────────────────── */

  .banner-scroll {
    width: 100%;
    overflow: hidden;
    padding: var(--space-8) 0;
  }

  .banner-track {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    width: max-content;
    will-change: transform;
  }

  .banner-item {
    flex-shrink: 0;
    width: 140px;
    height: 140px;
  }

  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid #FF69B4;
    display: block;
  }

  @media (min-width: 768px) {
    .banner-item {
      width: 180px;
      height: 180px;
    }
  }

  /* ── Bio strip ─────────────────────────────────────────────────────── */

  .bio-strip {
    width: 100%;
    min-height: 33vh;
    background-color: #f699cd;
    display: flex;
    align-items: center;
  }

  .bio-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: #000000;
    line-height: 1.1;
    margin: 0 0 var(--space-6) 0;
  }

  .interests-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: #FF69B4;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-6);
  }

  .bio-inner {
    padding: var(--space-8) var(--space-6);
    width: 100%;
    max-width: none;
  }

  .bio-text {
    font-size: var(--text-base);
    line-height: 1.8;
    color: #000000;
    font-weight: 400;
    margin: 0 0 1.1em 0;
  }

  .bio-text:last-child {
    margin-bottom: 0;
  }

  .bio-text a {
    color: #000000;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: color 0.15s ease;
  }

  .bio-text a:hover,
  .bio-text a:focus-visible {
    color: #ffffff;
  }

  @media (min-width: 768px) {
    .bio-inner {
      padding: var(--space-12) var(--space-10);
    }

    .bio-text {
      font-size: var(--text-lg);
    }
  }

  /* ── Photo grid ────────────────────────────────────────────────────── */

  .photo-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    padding: 0 var(--space-6) var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }

  .photo-item {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .photo-card {
    position: relative;
    width: 100%;
    height: 100%;
    cursor: pointer;
    background-color: var(--color-surface-alt);
    border: 2px solid #FF69B4;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: var(--space-4);
    opacity: 0;
  }

  .photo-caption {
    color: #FF69B4;
    font-family: 'Press Start 2P', cursive;
    font-size: calc(var(--text-sm) * 0.55);
    font-weight: 400;
    text-align: left;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .photo-grid {
      gap: var(--space-4);
      padding: 0 var(--space-8) var(--space-10);
    }

    .photo-caption {
      font-size: calc(var(--text-base) * 0.55);
    }
  }
</style>
