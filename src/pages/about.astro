---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SideNav from '../components/SideNav.astro';

// Caption is the text that types across the image on hover.
// alt is a short description used for screen readers / if an image fails to load.
type Photo = {
  src: string;
  alt: string;
  caption: string;
  /**
   * Dropped from the grid on phones. The grid is 4 across on desktop (16 photos
   * = a clean 4x4) and 3 across on phones, where 16 would leave a lone photo
   * stranded on a sixth row — so one is held back to make it an even 3x5.
   * Flagged here rather than sliced by index so reordering the list can't
   * silently drop a different photo. Every photo still appears in the banner.
   */
  desktopOnly?: boolean;
};

const photos: Photo[] = [
  { src: '/images/about/photo-1.jpg',  alt: 'reading',       caption: `Reading is my first love. I'll devour any book, from fact to fiction, but my true love is mystery books.` },
  { src: '/images/about/photo-2.jpg',  alt: 'studying',      caption: `While I complain constantly about studying, it's the one that got me 625 points in my leaving cert, and allowed me to maintain a strong 4.0 GPA in college.` },
  { src: '/images/about/photo-3.jpg',  alt: 'piano',         caption: `I've been playing piano since I was 7, though I've never gone past grade 6.` },
  { src: '/images/about/photo-4.jpg',  alt: 'coffee',        caption: `The one thing that gets me through every day. Working as a barista for 4 years certainly didn't help my obsession.` },
  { src: '/images/about/photo-5.jpg',  alt: 'rings',         caption: `Would I even be who I am without my rings? The oldest one in my stack is almost 90 y/o.` },
  { src: '/images/about/photo-6.jpg',  alt: 'food',          caption: `I love to cook and eat what can I say >-<` },
  { src: '/images/about/photo-7.jpg',  alt: 'speaking',      caption: `From model EU councils in my youth to global conferences, I've always loved the chance to share my experiences and thoughts - what can I say, I'm a yapper at heart.` },
  { src: '/images/about/photo-8.jpg',  alt: 'cybersecurity', caption: `My chosen career path and my second love, this is an area I knew I would dedicate my life to since I was 13.` },
  { src: '/images/about/photo-9.jpg',  alt: 'rover',         caption: `Wow what a cool rover! If only there was a whole page dedicated to it on a site somewhere....` },
  { src: '/images/about/photo-10.jpg', alt: 'fit check',     caption: `Okay so I want to be a fashionista, sue me. Not only do I make my own clothes, I also never shut up about it.` },
  { src: '/images/about/photo-11.jpg', alt: 'skiing',        caption: `Definitely my favorite sport.` },
  { src: '/images/about/photo-12.jpg', alt: 'NASA',          caption: `Did I mention the NASA astronaut training I did?` },
  { src: '/images/about/photo-13.jpg', alt: 'nature',        caption: `After all those darn screens sometimes touching grass is sorely needed.` },
  { src: '/images/about/photo-14.jpg', alt: 'Irish',         caption: `mo teanga feinig agus mo teanga is fear` },
  { src: '/images/about/photo-15.jpg', alt: 'gym',           caption: `Is fear an tsláinte ná an táinte - or whatever they say` },
  { src: '/images/about/photo-16.jpg', alt: 'cat',           caption: `My favorite animal and dream pet, this lil guy isn't mine though :(`, desktopOnly: true },
];
---

<BaseLayout title="About Me">
  <SiteHeader />
  <SideNav />
  <main>

    <!-- ── Scrolling circle banner ──────────────────────────────────── -->
    <!-- aria-hidden: same images appear accessibly in the grid below -->
    <section class="banner-scroll" aria-hidden="true">
      <ul class="banner-track">
        {photos.map(photo => (
          <li class="banner-item">
            <img src={photo.src} alt="" class="banner-img" width="160" height="160" />
          </li>
        ))}
        {photos.map(photo => (
          <li class="banner-item">
            <img src={photo.src} alt="" class="banner-img" width="160" height="160" loading="lazy" />
          </li>
        ))}
      </ul>
    </section>

    <!-- ── Pink bio strip ────────────────────────────────────────────── -->
    <section class="bio-strip" aria-label="About me">
      <div class="bio-inner">
        <h2 class="bio-heading">About me</h2>

        <!--
          Two copies of the bio, one tightened for phones, one full for wider
          screens. CSS shows exactly one (see .bio-body--* below) — the other is
          display:none, which also keeps it out of the accessibility tree, so a
          screen reader only ever meets one version.

          EDITING: these are separate copies of the same text. A change to one
          needs the same change in the other, or the two will drift apart.
        -->

        <div class="bio-body bio-body--compact">
          <p class="bio-text">
            I'm a Cybersecurity and IT Management student at Munster Technological University, and I currently chair <a href="/cybersoc">MTU's Cybersecurity Society</a>. My interest in security is hands-on: I've shadowed Johnson &amp; Johnson's cybersecurity team to see how threat detection works inside a large organisation, and I'm building toward a career in security engineering.
          </p>
          <p class="bio-text">
            I work in Python, C++, JavaScript, and Rust, and I like the kind of problem-solving that rewards patience, a habit I picked up competing in the European Girls' Mathematical Olympiad (top 10 in Ireland) and the national Programming Olympiad finals. I'm happiest when I'm building something real: I co-founded <a href="/portfolio#lynra">Lynra</a> at Dublin's Patch accelerator, training an object-detection model for a rover that delivers micro-injections to diseased ash trees. Earlier, my team won SciFest's Technology Category and the EirGrid Award for a 3D-printed carbon-capture filter for car exhausts. More recently, I built SÓShielta at Hack Europe with a four-person team.
          </p>
          <p class="bio-text">
            Outside the strictly technical stuff, I've trained as an astronaut at <a href="/awards">NASA's Space Camp</a> (and somehow came home with the Right Stuff Award). I read a lot — mystery novels especially — and I make my own clothes. Both scratch the same itch as everything else: figuring out how the pieces fit together, whether it's a network issue or a locked-room mystery.
          </p>
          <p class="bio-text">
            I'm always up for interesting projects and conversations — get in touch.
          </p>
        </div>

        <div class="bio-body bio-body--full">
          <p class="bio-text">
            I'm a Cybersecurity and IT Management student at Munster Technological University, and I currently chair <a href="/cybersoc">MTU's Cybersecurity Society</a>. My interest in security is hands-on: I've shadowed Johnson &amp; Johnson's cybersecurity team watching how threat detection actually works inside a large organisation, and I'm building toward a career in security engineering.
          </p>
          <p class="bio-text">
            I work in Python, C++, JavaScript, and Rust, and I like the kind of problem-solving that rewards patience, a habit I picked up competing in the European Girls' Mathematical Olympiad (top 10 in Ireland) and the national Programming Olympiad finals. I'm happiest when I'm building something real: I co-founded <a href="/portfolio#lynra">Lynra</a> at Dublin's Patch accelerator, training an object-detection model and putting it on a rover that delivers micro-injections to diseased ash trees. Earlier, a four-person team and I won SciFest's Technology Category and the EirGrid Award for a carbon-capture filter that used CAD and 3D printing to cut CO₂ from car exhausts. More recently I built SÓShielta at Hack Europe with a four-person team.
          </p>
          <p class="bio-text">
            Outside the strictly technical stuff, I've trained as an astronaut at <a href="/awards">NASA's Space Camp</a> (and somehow came home with the Right Stuff Award). I read a lot — mystery novels especially — and I make my own clothes. Both scratch the same itch as everything else: at heart I'm a problem-solver, the kind who's just as happy untangling a network connectivity issue as a locked-room murder; figuring out how the pieces fit together to make something that works.
          </p>
          <p class="bio-text">
            I'm always up for interesting projects and conversations — get in touch.
          </p>
        </div>
      </div>
    </section>

    <!-- ── Photo grid: 3 across on phones (3 × 5), 4 across above ────── -->
    <h2 class="interests-heading">my interests</h2>
    <ul class="photo-grid" aria-label="Photo gallery">
      {photos.map(photo => (
        <li class:list={['photo-item', { 'photo-item--desktop-only': photo.desktopOnly }]}>
          <button
            class="photo-card"
            type="button"
            data-caption={photo.caption}
            aria-label={`${photo.alt} — read the note`}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="photo-img"
              loading="lazy"
              width="300"
              height="400"
            />
            <div class="photo-overlay" aria-hidden="true">
              <span class="photo-caption"></span>
            </div>
          </button>
        </li>
      ))}
    </ul>

  </main>
  <SiteFooter />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { TextPlugin } from 'gsap/TextPlugin';

  gsap.registerPlugin(TextPlugin);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Banner scroll
  const bannerTrack = document.querySelector<HTMLElement>('.banner-track');
  if (bannerTrack && !prefersReducedMotion) {
    gsap.to(bannerTrack, {
      xPercent: -50,
      duration: 30,
      ease: 'none',
      repeat: -1,
    });
  }

  // ── Photo cards ──────────────────────────────────────────────────────────
  // Hover shows a quick preview of the note. Clicking (or tapping) is the real
  // path: the tile grows out to a centred panel, then the photo dissolves out
  // from underneath the caption as the caption types over it. Hover never fired
  // on a phone, so before this the notes were unreachable on touch entirely.

  const canHover = window.matchMedia('(hover: hover)').matches;

  const EXPAND_MARGIN = 24;   // gap left around the panel at the viewport edge
  const EXPAND_MAX_W  = 460;  // don't blow the tile up past legible on a desktop

  /** Centred landing box, 3:4 like the tiles, clamped to whichever axis binds. */
  function expandedBox() {
    let w = Math.min(window.innerWidth - EXPAND_MARGIN * 2, EXPAND_MAX_W);
    let h = w * 4 / 3;
    const maxH = window.innerHeight - EXPAND_MARGIN * 2;
    if (h > maxH) {
      h = maxH;
      w = h * 3 / 4;
    }
    return { w, h, left: (window.innerWidth - w) / 2, top: (window.innerHeight - h) / 2 };
  }

  // Only ever one panel open, and closing it is the same call from every route
  // out (scrim click, panel click, Escape).
  let closeActive: (() => void) | null = null;

  function expand(card: HTMLElement, text: string): void {
    if (closeActive) return;

    const sourceImg = card.querySelector<HTMLImageElement>('.photo-img');
    const rect = card.getBoundingClientRect();

    const scrim = document.createElement('div');
    scrim.className = 'photo-zoom-scrim';

    const box = document.createElement('div');
    box.className = 'photo-zoom';
    box.setAttribute('role', 'dialog');
    box.setAttribute('aria-modal', 'true');
    // Screen readers get the caption whole, here. The visible copy types itself
    // in a character at a time, which would be gibberish announced live — so
    // that copy is aria-hidden below.
    box.setAttribute('aria-label', text);
    box.tabIndex = -1;
    box.style.left   = `${rect.left}px`;
    box.style.top    = `${rect.top}px`;
    box.style.width  = `${rect.width}px`;
    box.style.height = `${rect.height}px`;

    const img = document.createElement('img');
    img.className = 'photo-zoom-img';
    img.alt = '';
    img.src = sourceImg?.currentSrc || sourceImg?.src || '';

    const cap = document.createElement('p');
    cap.className = 'photo-zoom-caption';
    cap.setAttribute('aria-hidden', 'true');

    box.append(img, cap);
    document.body.append(scrim, box);

    // The clone starts exactly over the tile, so hiding the tile costs nothing
    // visually on frame one and stops it sitting there under the scrim once the
    // clone has grown away from it.
    card.style.visibility = 'hidden';
    const scrollLock = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
    box.focus();

    const target  = expandedBox();
    const typeDur = Math.max(0.5, text.length * 0.04); // same rate as the hover preview
    const typer   = { i: 0 };
    let tl: gsap.core.Timeline | undefined;

    if (prefersReducedMotion) {
      box.style.left   = `${target.left}px`;
      box.style.top    = `${target.top}px`;
      box.style.width  = `${target.w}px`;
      box.style.height = `${target.h}px`;
      gsap.set(scrim, { opacity: 1 });
      gsap.set(img, { opacity: 0 });
      cap.textContent = text;
    } else {
      tl = gsap.timeline();
      tl.to(scrim, { opacity: 1, duration: 0.25 }, 0);
      tl.to(box, {
        left: target.left,
        top: target.top,
        width: target.w,
        height: target.h,
        duration: 0.45,
        ease: 'power2.inOut',
      }, 0);
      // Both start as the growth ends: the photo dissolves away underneath the
      // words as the words land on top of it.
      tl.to(img, { opacity: 0, duration: Math.min(typeDur, 1.1), ease: 'power1.in' }, 0.45);
      tl.to(typer, {
        i: text.length,
        duration: typeDur,
        ease: 'none',
        // Typed via textContent rather than TextPlugin: TextPlugin writes
        // innerHTML, and a caption ending ">-<" loses its tail to the HTML
        // parser, which is why that one reads short on hover.
        onUpdate() {
          cap.textContent = text.slice(0, Math.round(typer.i));
        },
      }, 0.45);
    }

    function onKey(e: KeyboardEvent): void {
      if (e.key === 'Escape') close();
    }

    function close(): void {
      if (!closeActive) return;
      closeActive = null;
      tl?.kill();
      document.body.style.overflow = scrollLock;
      window.removeEventListener('keydown', onKey);

      // Re-measured rather than reused: the grid may have reflowed, and on a
      // phone the address bar collapsing counts as a resize.
      const back = card.getBoundingClientRect();

      const done = () => {
        box.remove();
        scrim.remove();
        card.style.visibility = '';
        card.focus();
      };

      if (prefersReducedMotion) {
        done();
        return;
      }

      gsap.timeline({ onComplete: done })
        .to(cap, { opacity: 0, duration: 0.15 }, 0)
        .to(img, { opacity: 1, duration: 0.3 }, 0)
        .to(box, {
          left: back.left,
          top: back.top,
          width: back.width,
          height: back.height,
          duration: 0.4,
          ease: 'power2.inOut',
        }, 0.05)
        .to(scrim, { opacity: 0, duration: 0.4 }, 0.05);
    }

    closeActive = close;
    scrim.addEventListener('click', close);
    box.addEventListener('click', close);
    window.addEventListener('keydown', onKey);
  }

  document.querySelectorAll<HTMLElement>('.photo-card').forEach(card => {
    const overlay   = card.querySelector<HTMLElement>('.photo-overlay');
    const captionEl = card.querySelector<HTMLElement>('.photo-caption');
    const text = card.dataset.caption ?? '';

    if (!overlay || !captionEl) return;

    let hoverTween: gsap.core.Tween | undefined;

    const clearHover = () => {
      hoverTween?.kill();
      captionEl.textContent = '';
      gsap.set(overlay, { opacity: 0 });
    };

    // Gated on real hover capability: on a touch screen a tap synthesises
    // mouseenter, which would flash the tiny preview under the panel opening.
    if (canHover) {
      card.addEventListener('mouseenter', () => {
        hoverTween?.kill();
        if (prefersReducedMotion) {
          gsap.set(overlay, { opacity: 1 });
          if (text) captionEl.textContent = text;
          return;
        }
        gsap.to(overlay, { opacity: 1, duration: 0.2 });
        if (text) {
          hoverTween = gsap.to(captionEl, {
            text,
            duration: Math.max(0.5, text.length * 0.04),
            ease: 'none',
            delay: 0.15,
          });
        }
      });

      card.addEventListener('mouseleave', () => {
        hoverTween?.kill();
        captionEl.textContent = '';
        gsap.to(overlay, { opacity: 0, duration: 0.3 });
      });
    }

    card.addEventListener('click', () => {
      clearHover();
      expand(card, text);
    });
  });

</script>

<style>
  main {
    min-height: 100svh;
  }

  /* ── Scrolling circle banner ───────────────────────────────────────── */

  /* Height is just the circle plus its padding, so `--banner-size` is the one
     number to turn: the strip is that plus 2 x the padding either side.
     Phones: 96 + 40 = 136px, down from 204px, which was eating close to a
     third of the viewport before you reached a word of the bio. */
  .banner-scroll {
    --banner-size: 96px;

    width: 100%;
    overflow: hidden;
    padding: var(--space-5) 0;
  }

  .banner-track {
    display: flex;
    /* Tighter alongside smaller circles, so the strip stays as densely packed
       as it looks now rather than reading as gaps with photos between them. */
    gap: var(--space-4);
    list-style: none;
    width: max-content;
    will-change: transform;
  }

  .banner-item {
    flex-shrink: 0;
    width: var(--banner-size);
    height: var(--banner-size);
  }

  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid #FF69B4;
    display: block;
  }

  @media (min-width: 768px) {
    /* 140 + 48 = 188px, down from 244px. */
    .banner-scroll {
      --banner-size: 140px;
      padding: var(--space-6) 0;
    }

    .banner-track {
      gap: var(--space-6);
    }
  }

  /* ── Bio strip ─────────────────────────────────────────────────────── */

  .bio-strip {
    width: 100%;
    min-height: 33vh;
    background-color: #f699cd;
    display: flex;
    align-items: center;
  }

  .bio-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: #000000;
    line-height: 1.1;
    margin: 0 0 var(--space-6) 0;
  }

  .interests-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: #FF69B4;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-6);
  }

  .bio-inner {
    padding: calc(var(--space-8) * 1.75) calc(var(--space-6) * 1.75);
    width: 100%;
    max-width: none;
  }

  .bio-text {
    font-size: var(--text-base);
    line-height: 1.8;
    color: #000000;
    font-weight: 300;
    margin: 0 0 1.1em 0;
  }

  .bio-text:last-child {
    margin-bottom: 0;
  }

  /* Bio variants. `display: contents` rather than `block` so the wrapper leaves
     no box of its own behind: the paragraphs stay direct children of .bio-inner
     as far as layout is concerned, and the spacing is byte-for-byte what it was
     before the wrapper existed. Each copy carries its own closing line so
     `.bio-text:last-child` above still zeroes the final margin within it. */
  .bio-body--compact {
    display: contents;
  }

  .bio-body--full {
    display: none;
  }

  .bio-text a {
    color: #000000;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: color 0.15s ease;
  }

  .bio-text a:hover,
  .bio-text a:focus-visible {
    color: #ffffff;
  }

  @media (min-width: 768px) {
    .bio-inner {
      padding: calc(var(--space-12) * 1.75) calc(var(--space-10) * 1.75);
    }

    .bio-text {
      font-size: var(--text-lg);
    }

    .bio-body--compact {
      display: none;
    }

    .bio-body--full {
      display: contents;
    }
  }

  /* ── Photo grid ────────────────────────────────────────────────────── */

  /* Phones: 3 across. With the desktop-only photo hidden that is 15 tiles,
     landing as an exact 3 × 5 with no ragged final row. Four across on a
     phone left each tile around 78px wide — too small to read a caption in. */
  .photo-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    padding: 0 var(--space-6) var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }

  .photo-item {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .photo-item--desktop-only {
    display: none;
  }

  /* A <button>, so the notes are reachable by keyboard and announced as
     activatable — hence the appearance reset before the card styling. */
  .photo-card {
    display: block;
    padding: 0;
    font: inherit;
    color: inherit;
    text-align: left;
    -webkit-appearance: none;
    appearance: none;

    position: relative;
    width: 100%;
    height: 100%;
    cursor: pointer;
    background-color: var(--color-surface-alt);
    border: 2px solid #FF69B4;
  }

  .photo-card:focus-visible {
    outline: none;
    border-color: #FFB3D9;
    box-shadow: 0 0 0 3px rgba(255, 105, 180, 0.5);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: var(--space-4);
    opacity: 0;
  }

  .photo-caption {
    color: #FF69B4;
    font-family: 'Press Start 2P', cursive;
    font-size: calc(var(--text-sm) * 0.55);
    font-weight: 400;
    text-align: left;
    line-height: 1.6;
  }

  :global([data-theme="light"]) .photo-overlay {
    background-color: rgba(255, 255, 255, 0.9);
  }

  :global([data-theme="light"]) .photo-caption {
    color: #000000;
  }

  /* ── Expanded panel ────────────────────────────────────────────────────
     Built by JS and appended to <body>, so it sits outside this component's
     scoping — :global() is what lets these rules reach it. */

  :global(.photo-zoom-scrim) {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background-color: rgba(0, 0, 0, 0.75);
    opacity: 0;
    cursor: pointer;
  }

  :global([data-theme="light"] .photo-zoom-scrim) {
    background-color: rgba(255, 255, 255, 0.8);
  }

  /* Sized and positioned entirely from JS: it starts life matching the tile's
     bounding box and is animated to the centred box from there. The background
     is what the photo dissolves away to reveal. */
  :global(.photo-zoom) {
    position: fixed;
    z-index: 9001;
    overflow: hidden;
    cursor: pointer;
    background-color: rgba(0, 0, 0, 0.92);
    border: 2px solid #FF69B4;
  }

  :global([data-theme="light"] .photo-zoom) {
    background-color: rgba(255, 255, 255, 0.94);
  }

  :global(.photo-zoom-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(.photo-zoom-caption) {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: var(--space-5);
    overflow-y: auto;
    color: #FF69B4;
    font-family: 'Press Start 2P', cursive;
    font-weight: 400;
    /* Press Start 2P is wide and the longest note runs ~200 characters, so this
       stays small enough for it to fit the panel without scrolling on a phone. */
    font-size: clamp(9px, 2.6vw, 13px);
    line-height: 1.8;
  }

  :global([data-theme="light"] .photo-zoom-caption) {
    color: #000000;
  }

  @media (min-width: 768px) {
    /* Back to the full set: 4 across, all 16 photos, a clean 4 × 4. */
    .photo-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
      padding: 0 var(--space-8) var(--space-10);
    }

    .photo-item--desktop-only {
      display: list-item;
    }

    .photo-caption {
      font-size: calc(var(--text-base) * 0.55);
    }
  }
</style>
