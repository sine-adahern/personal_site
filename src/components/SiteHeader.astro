---
// SiteHeader renders on every page, so the name is a <p> not <h1>.
// Each page provides its own <h1> for the page title, keeping one <h1> per page.
---

<header class="site-header">
  <p class="site-title">Sinéad Ahern</p>
</header>

<style>
  .site-header {
    padding: var(--space-4) var(--space-6);
    background-color: var(--color-background);
  }

  .site-title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .site-header {
      padding: var(--space-6) var(--space-8);
    }

    .site-title {
      font-size: var(--text-4xl);
    }
  }
</style>
