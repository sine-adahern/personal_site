---
const navItems = [
  { name: 'Home',      href: '/',         thumb: '/thumbs/thumb-home.svg'      },
  { name: 'About Me',  href: '/about',    thumb: '/thumbs/thumb-about.svg'     },
  { name: 'Portfolio', href: '/projects', thumb: '/thumbs/thumb-portfolio.svg' },
  { name: 'Trips',     href: '/trips',    thumb: '/thumbs/thumb-trips.svg'     },
  { name: 'Cyber SOC', href: '/cybersoc', thumb: '/thumbs/thumb-cybersoc.svg'  },
  { name: 'Patch',           href: '/patch',     thumb: '/thumbs/thumb-patch.svg'     },
  { name: 'Public Speaking', href: '/speaking',  thumb: '/thumbs/thumb-speaking.svg'  },
];
---

<button
  class="sidenav-toggle"
  aria-label="Open navigation menu"
  aria-expanded="false"
  aria-controls="sidenav-drawer"
>
  <span class="bar"></span>
  <span class="bar"></span>
  <span class="bar"></span>
</button>

<div class="sidenav-overlay" aria-hidden="true"></div>

<nav
  class="sidenav-drawer"
  id="sidenav-drawer"
  aria-label="Page navigation"
  aria-hidden="true"
>
  <ul class="sidenav-list">
    {navItems.map(item => (
      <li>
        <a href={item.href} class="sidenav-link">
          <img
            src={item.thumb}
            alt={`Preview of the ${item.name} page`}
            class="sidenav-thumb"
            width="240"
            height="135"
            loading="lazy"
          />
          <span class="sidenav-name">{item.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  import { gsap } from 'gsap';

  const toggle  = document.querySelector<HTMLButtonElement>('.sidenav-toggle');
  const drawer  = document.querySelector<HTMLElement>('.sidenav-drawer');
  const overlay = document.querySelector<HTMLElement>('.sidenav-overlay');

  if (toggle && drawer && overlay) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dur = prefersReducedMotion ? 0 : 0.32;

    let isOpen = false;

    function open(): void {
      isOpen = true;
      drawer!.removeAttribute('aria-hidden');
      toggle!.setAttribute('aria-expanded', 'true');
      toggle!.setAttribute('aria-label', 'Close navigation menu');
      toggle!.classList.add('is-open');
      overlay!.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
      gsap.to(drawer!, { x: 0, duration: dur, ease: 'power2.out' });
      gsap.to(overlay!, { opacity: 1, duration: dur, ease: 'power2.out' });
    }

    function close(): void {
      isOpen = false;
      toggle!.setAttribute('aria-expanded', 'false');
      toggle!.setAttribute('aria-label', 'Open navigation menu');
      toggle!.classList.remove('is-open');
      document.body.style.overflow = '';
      gsap.to(drawer!, {
        x: '100%',
        duration: dur,
        ease: 'power2.in',
        onComplete() {
          drawer!.setAttribute('aria-hidden', 'true');
          overlay!.classList.remove('is-visible');
        },
      });
      gsap.to(overlay!, { opacity: 0, duration: dur, ease: 'power2.in' });
    }

    toggle.addEventListener('click', () => { if (isOpen) close(); else open(); });
    overlay.addEventListener('click', close);
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isOpen) close();
    });
  }
</script>

<style>
  /* ── Hamburger button ───────────────────────────────────────────── */

  .sidenav-toggle {
    position: fixed;
    top: var(--space-4);
    right: var(--space-6);
    z-index: 300;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-1);
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .sidenav-toggle:focus-visible {
    outline: 2px solid #FF69B4;
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #FF69B4;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  /* Morph to × when drawer is open */
  .sidenav-toggle.is-open .bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .sidenav-toggle.is-open .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .sidenav-toggle.is-open .bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* ── Overlay ────────────────────────────────────────────────────── */

  .sidenav-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.65);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
  }

  .sidenav-overlay.is-visible {
    pointer-events: auto;
  }

  /* ── Drawer ─────────────────────────────────────────────────────── */

  .sidenav-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 280px;
    z-index: 250;
    background-color: #000000;
    border-left: 2px solid #FF69B4;
    overflow-y: auto;
    transform: translateX(100%);
  }

  .sidenav-list {
    list-style: none;
    padding: var(--space-16) var(--space-4) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidenav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-decoration: none;
    color: #FF69B4;
    transition: color 0.2s;
  }

  .sidenav-link:hover {
    color: #FFB3D9;
  }

  .sidenav-link:hover .sidenav-thumb {
    border-color: #FFB3D9;
  }

  .sidenav-link:focus-visible {
    outline: 2px solid #FF69B4;
    outline-offset: 3px;
    border-radius: var(--radius-sm);
    color: #FFB3D9;
  }

  .sidenav-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border: 1px solid rgba(255, 105, 180, 0.35);
    transition: border-color 0.2s;
  }

  .sidenav-name {
    font-size: var(--text-sm);
    font-weight: 700;
    padding: 0 var(--space-1);
  }

  @media (min-width: 768px) {
    .sidenav-drawer {
      width: 320px;
    }
  }
</style>
