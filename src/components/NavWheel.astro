---
import { panels } from '../data/panels';
import HomeMini from './HomeMini.astro';
---

<nav class="nav-wheel" aria-label="Site navigation">
  <ul class="wheel-track">
    {/* Shadow footprints — rendered before panels so DOM order puts them underneath.
        JS sets per-panel floor transforms inside initWheel. */}
    {panels.map(() => (
      <li class="wheel-shadow" role="presentation" aria-hidden="true"></li>
    ))}

    {panels.map((panel) => (
      <li class="wheel-panel">
        <a href={panel.href} class="panel-card">
          {panel.mini ? (
            /* The Home card shows the page itself, rebuilt small and live,
               rather than a picture of it. See HomeMini.astro. */
            <HomeMini />
          ) : (
            <Fragment>
              <img
                src={panel.thumb}
                alt={`Preview of the ${panel.name} page`}
                class={panel.thumbLight ? 'panel-thumb thumb-dark' : 'panel-thumb'}
                width="320"
                height="180"
              />
              {panel.thumbLight && (
                <img
                  src={panel.thumbLight}
                  alt={`Preview of the ${panel.name} page`}
                  class="panel-thumb thumb-light"
                  width="320"
                  height="180"
                />
              )}
            </Fragment>
          )}
          <span class="panel-name">{panel.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  import { gsap } from 'gsap';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    initWheel();
  }

  function initWheel(): void {
    const navEl  = document.querySelector<HTMLElement>('.nav-wheel');
    const trackEl = document.querySelector<HTMLElement>('.wheel-track');
    const panelEls  = Array.from(document.querySelectorAll<HTMLElement>('.wheel-panel'));
    const shadowEls = Array.from(document.querySelectorAll<HTMLElement>('.wheel-shadow'));

    // The live miniature on the Home card (HomeMini.astro). Its wheel is driven
    // from the same angle as the big one, so the picture of the site always
    // shows the site as it is right now.
    const miniEl        = document.querySelector<HTMLElement>('.panel-mini');
    const miniPanelEls  = Array.from(document.querySelectorAll<HTMLElement>('.mini-panel'));
    const miniShadowEls = Array.from(document.querySelectorAll<HTMLElement>('.mini-shadow'));

    if (!navEl || !trackEl || panelEls.length === 0) return;

    const nav   = navEl;
    const track = trackEl;

    const PANEL_COUNT = panelEls.length;
    const ANGLE_STEP  = 360 / PANEL_COUNT;

    const RADIUS_MOBILE  = 450;
    const RADIUS_DESKTOP = 780;
    let radius = window.innerWidth >= 768 ? RADIUS_DESKTOP : RADIUS_MOBILE;

    // Card height drives the floor offset (translateY to panel bottom edge).
    // On phones the CSS sizes the card from the viewport, so this is measured
    // rather than assumed. offsetHeight is a layout box: rotation and
    // perspective don't touch it, unlike getBoundingClientRect().
    const CARD_HEIGHT_MOBILE  = 162;
    const CARD_HEIGHT_DESKTOP = 270;

    function measureCardHeight(): number {
      return track.offsetHeight
        || (window.innerWidth >= 768 ? CARD_HEIGHT_DESKTOP : CARD_HEIGHT_MOBILE);
    }

    // Must precede the measurement: until this class lands the track is still
    // the stacked-list fallback, and would measure as tall as the whole column.
    nav.classList.add('is-wheel');

    let cardHeight = measureCardHeight();

    const state = { angle: 0 };

    // ── Miniature ─────────────────────────────────────────────────────────────
    // The miniature scales itself (HomeMini.astro owns `--u`); all it needs
    // from here is the angle.
    /**
     * Position the miniature's cards for a given wheel angle.
     *
     * The big wheel rotates its track by -angle and each panel by its own slot
     * angle. Rotations about a shared Y axis add, so one `rotateY(slot - angle)`
     * per card is the same transform — which is what lets the miniature use
     * self-contained perspective() instead of a nested 3D scene. Depth sorting
     * is done by hand via z-index, since a flattened scene has none.
     */
    function updateMini(angle: number): void {
      if (!miniEl) return;

      miniPanelEls.forEach((miniPanel, i) => {
        const diff = ((i * ANGLE_STEP - angle) % 360 + 540) % 360 - 180;
        const proximity = Math.cos((diff * Math.PI) / 180);

        const scale = 0.8 + 0.2 * Math.max(0, proximity);
        miniPanel.style.transform =
          'perspective(calc(var(--mini-persp) * var(--u))) ' +
          `rotateY(${diff}deg) ` +
          'translateZ(calc(var(--mini-radius) * var(--u))) ' +
          `scale(${scale})`;
        miniPanel.style.opacity = String(0.4 + 0.6 * ((proximity + 1) / 2));
        miniPanel.style.zIndex  = String(Math.round(proximity * 1000) + 2000);

        // Shadows sit in a band below every card, so the whole set stays under
        // the whole set of cards — close enough at this scale, and it saves
        // interleaving two z ranges every frame.
        const miniShadow = miniShadowEls[i];
        if (miniShadow) {
          const shadowScale = 1.0 + 0.4 * ((1 - proximity) / 2);
          miniShadow.style.transform =
            'perspective(calc(var(--mini-persp) * var(--u))) ' +
            `rotateY(${diff}deg) ` +
            'translateZ(calc((var(--mini-radius) - 1) * var(--u))) ' +
            'translateY(calc(var(--mini-cardh) * var(--u) / 2)) ' +
            'rotateX(-90deg) ' +
            `scale(${shadowScale})`;
          miniShadow.style.opacity = String(0.1 + 0.55 * ((proximity + 1) / 2));
          miniShadow.style.zIndex  = String(Math.round(proximity * 1000) + 500);
        }
      });
    }

    function updateEmphasis(): void {
      panelEls.forEach((panel, i) => {
        const panelAngle = i * ANGLE_STEP;
        // Normalise diff to [-180, 180] so cos gives 1 at front, -1 at back
        const diff = ((panelAngle - state.angle) % 360 + 540) % 360 - 180;
        const proximity = Math.cos((diff * Math.PI) / 180);

        // ── Panel ───────────────────────────────────────────────────────────
        const opacity = 0.4 + 0.6 * ((proximity + 1) / 2);
        const scale   = 0.8 + 0.2 * Math.max(0, proximity);
        panel.style.transform =
          `rotateY(${panelAngle}deg) translateZ(${radius}px) scale(${scale})`;
        panel.style.opacity = String(opacity);

        // ── Shadow ──────────────────────────────────────────────────────────
        // Shadow elements are siblings in the same preserve-3d track, so their
        // transforms are independent — panel scale does not affect them.
        //
        // Transform chain:
        //   rotateY(panelAngle)          — orbit to this panel's ring slot
        //   translateZ(radius - 1)       — same ring radius, 1px behind panel
        //   translateY(cardHeight / 2)   — drop to panel's bottom edge (floor)
        //   rotateX(-90deg)              — tip flat; face points upward, visible
        //   scale(shadowScale)           — broader + fainter further from front
        //
        // Front (proximity=1): opacity≈0.65, scale=1.0 → tight dark footprint
        // Rear  (proximity=-1): opacity≈0.1,  scale=1.4 → wide faint haze
        const shadow = shadowEls[i];
        if (shadow) {
          const shadowOpacity = 0.1 + 0.55 * ((proximity + 1) / 2);
          const shadowScale   = 1.0 + 0.4  * ((1 - proximity) / 2);
          shadow.style.transform =
            `rotateY(${panelAngle}deg) ` +
            `translateZ(${radius - 1}px) ` +
            `translateY(${cardHeight / 2}px) ` +
            `rotateX(-90deg) ` +
            `scale(${shadowScale})`;
          shadow.style.opacity = String(shadowOpacity);
        }
      });

      updateMini(state.angle);
    }

    function rotateTo(target: number, duration = 0.8, onComplete?: () => void): void {
      gsap.to(state, {
        angle: target,
        duration,
        ease: 'power2.out',
        onUpdate() {
          track.style.transform = `rotateY(${-state.angle}deg)`;
          updateEmphasis();
        },
        onComplete,
      });
    }

    // ── Ambient auto-rotation ────────────────────────────────────────────────
    // Drifts continuously when idle; user scroll/touch input takes over
    // immediately and the drift resumes a couple seconds after input stops.
    const AUTOPLAY_DEG_PER_SEC = 5; // ~72s per revolution
    const AUTOPLAY_RESUME_DELAY = 2500; // ms of inactivity before drift resumes

    let autoplayTween: gsap.core.Tween | undefined;
    let resumeTimer: ReturnType<typeof setTimeout> | undefined;

    function startAutoplay(): void {
      autoplayTween = gsap.to(state, {
        angle: '+=360',
        duration: 360 / AUTOPLAY_DEG_PER_SEC,
        ease: 'none',
        repeat: -1,
        modifiers: { angle: gsap.utils.wrap(0, 360) },
        onUpdate() {
          track.style.transform = `rotateY(${-state.angle}deg)`;
          updateEmphasis();
        },
      });
    }

    function stopAutoplay(): void {
      if (!autoplayTween) return;
      autoplayTween.kill();
      autoplayTween = undefined;
      scrollAngle = state.angle;
    }

    function scheduleAutoplayResume(): void {
      clearTimeout(resumeTimer);
      resumeTimer = setTimeout(startAutoplay, AUTOPLAY_RESUME_DELAY);
    }

    updateEmphasis();
    startAutoplay();

    // ── Wheel scroll ──────────────────────────────────────────────────────────
    let scrollAngle = 0;
    let snapTimer: ReturnType<typeof setTimeout> | undefined;

    nav.addEventListener(
      'wheel',
      (e: WheelEvent) => {
        // Only intercept horizontal-dominant events so vertical scroll
        // (trackpad two-finger up/down) reaches the browser normally.
        if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
        e.preventDefault();
        stopAutoplay();
        scrollAngle += e.deltaX * 0.15;
        rotateTo(scrollAngle);
        clearTimeout(snapTimer);
        snapTimer = setTimeout(() => {
          const snapped = Math.round(scrollAngle / ANGLE_STEP) * ANGLE_STEP;
          scrollAngle = snapped;
          rotateTo(snapped, 0.4);
          scheduleAutoplayResume();
        }, 500);
      },
      { passive: false },
    );

    // ── Touch swipe ───────────────────────────────────────────────────────────
    let touchStartX = 0;
    let touchStartAngle = 0;

    nav.addEventListener('touchstart', (e: TouchEvent) => {
      const touch = e.touches[0];
      if (!touch) return;
      stopAutoplay();
      touchStartX = touch.clientX;
      touchStartAngle = scrollAngle;
    });

    nav.addEventListener(
      'touchmove',
      (e: TouchEvent) => {
        e.preventDefault();
        const touch = e.touches[0];
        if (!touch) return;
        scrollAngle = touchStartAngle - (touch.clientX - touchStartX) * 0.3;
        rotateTo(scrollAngle, 0.15);
      },
      { passive: false },
    );

    nav.addEventListener('touchend', () => {
      const snapped = Math.round(scrollAngle / ANGLE_STEP) * ANGLE_STEP;
      scrollAngle = snapped;
      rotateTo(snapped, 0.5);
      scheduleAutoplayResume();
    });

    // ── Resize ────────────────────────────────────────────────────────────────
    window.addEventListener('resize', () => {
      radius     = window.innerWidth >= 768 ? RADIUS_DESKTOP  : RADIUS_MOBILE;
      cardHeight = measureCardHeight();
      updateEmphasis();
    });

    // ── Click → expand to full screen → navigate ──────────────────────────────
    // The clicked card grows from its on-screen box to fill the viewport, then
    // we navigate. The expanded image is handed to the next page via
    // sessionStorage (see the is:inline script in BaseLayout), which paints it
    // full-bleed before first paint and dissolves it away — so the document
    // swap happens underneath a still image and never reads as a cut.
    const EXPAND_DURATION = 0.6;
    const CLONE_CLASS = 'wheel-clone';

    let isNavigating = false;

    panelEls.forEach((panel, i) => {
      const card = panel.querySelector<HTMLAnchorElement>('.panel-card');
      if (!card) return;

      card.addEventListener('click', (e: MouseEvent) => {
        // Let the browser handle new-tab / new-window / middle clicks.
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
        e.preventDefault();
        if (isNavigating) return;
        launch(i, card.href, card);
      });
    });

    /** The theme swap is display:none, so ask the browser which img is showing. */
    function visibleThumb(panel: HTMLElement): HTMLImageElement | null {
      const imgs = Array.from(panel.querySelectorAll<HTMLImageElement>('.panel-thumb'));
      return imgs.find((img) => getComputedStyle(img).display !== 'none') ?? imgs[0] ?? null;
    }

    function launch(index: number, href: string, card: HTMLElement): void {
      const panel = panelEls[index];
      if (!panel) {
        window.location.href = href;
        return;
      }

      isNavigating = true;
      stopAutoplay();
      clearTimeout(resumeTimer);
      clearTimeout(snapTimer);

      // Bring the clicked panel to the front BEFORE measuring it. Only at the
      // front is the card flat and facing the camera, so getBoundingClientRect()
      // returns the box the user actually sees. On a side card the rect is the
      // bounding box of a rotated quad — wider than the visible face — and the
      // clone would snap to the wrong size on frame one.
      const delta   = (((index * ANGLE_STEP - state.angle) % 360) + 540) % 360 - 180;
      const target  = state.angle + delta;
      const isFront = Math.abs(delta) < 0.5;
      scrollAngle = target;

      rotateTo(target, isFront ? 0 : 0.4, () => expand(panel, card, href));
    }

    function expand(panel: HTMLElement, card: HTMLElement, href: string): void {
      const img  = visibleThumb(panel);
      const src  = img?.currentSrc || img?.src || '';
      const mini = panel.querySelector<HTMLElement>('.panel-mini');
      const rect = card.getBoundingClientRect();

      const clone = document.createElement('div');
      clone.className = CLONE_CLASS;
      clone.style.cssText = [
        'position: fixed',
        `left: ${rect.left}px`,
        `top: ${rect.top}px`,
        `width: ${rect.width}px`,
        `height: ${rect.height}px`,
        'overflow: hidden',
        'border: 2px solid #FF69B4',
        'z-index: 9998',
        'pointer-events: none',
      ].join(';');

      if (mini) {
        // The Home card has no thumbnail to blow up — it has the page itself.
        // Clone the miniature and let the growing box carry it: its lengths are
        // container-relative, so as the box reaches viewport size the small copy
        // resolves to exactly the real thing. The wheel opens into itself.
        const miniClone = mini.cloneNode(true) as HTMLElement;
        miniClone.style.setProperty('--vw', String(window.innerWidth));
        // Fill the growing box on both axes — the 16:9 sizing it uses in the
        // card would leave a band once the box takes the viewport's shape.
        miniClone.style.position    = 'absolute';
        miniClone.style.inset       = '0';
        miniClone.style.width       = 'auto';
        miniClone.style.aspectRatio = 'auto';
        clone.style.backgroundColor = 'var(--color-background)';
        clone.appendChild(miniClone);
      } else {
        clone.style.backgroundImage    = `url("${src}")`;
        clone.style.backgroundSize     = 'cover';
        clone.style.backgroundPosition = 'center';
      }

      document.body.appendChild(clone);

      // Hide the real card so it doesn't ghost underneath the growing clone.
      panel.style.visibility = 'hidden';

      try {
        // The miniature has no single image to hand over, and it lands on the
        // page it already depicts, so it skips the cross-page cover.
        if (!mini) {
          sessionStorage.setItem('pt:cover', JSON.stringify({ src, t: Date.now() }));
        }
      } catch {
        // Private mode / storage disabled — the expand still runs, the next
        // page just appears without the dissolve.
      }

      gsap.to([nav, '.site-header', '.site-footer', '.theme-toggle'], {
        opacity: 0,
        duration: 0.35,
        ease: 'power2.out',
      });

      gsap.to(clone, {
        left: 0,
        top: 0,
        width: window.innerWidth,
        height: window.innerHeight,
        borderWidth: 0,
        duration: EXPAND_DURATION,
        ease: 'power2.inOut',
        onComplete() {
          window.location.href = href;
        },
      });
    }

    // Back/forward from bfcache restores this page mid-transition: clone still
    // in the DOM, chrome still faded out, panel still hidden. Undo all of it.
    window.addEventListener('pageshow', (e) => {
      if (!(e as PageTransitionEvent).persisted) return;

      document.querySelectorAll(`.${CLONE_CLASS}`).forEach((el) => el.remove());
      gsap.set([nav, '.site-header', '.site-footer', '.theme-toggle'], { opacity: 1 });
      panelEls.forEach((panel) => { panel.style.visibility = ''; });

      isNavigating = false;
      updateEmphasis();
      startAutoplay();
    });
  }
</script>

<style>
  /* ─── Base: stacked list (no-JS / reduced motion) ─── */

  .nav-wheel {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: var(--space-8) var(--space-4);
    min-height: 100svh;
  }

  .wheel-track {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    width: 100%;
    max-width: 480px;
  }

  /* Shadows are invisible in the stacked-list fallback — no floor, no wheel. */
  .wheel-shadow {
    display: none;
  }

  .wheel-panel {
    width: 100%;
  }

  .panel-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text-secondary);
    background-color: var(--color-surface);
    border: 2px solid #FF69B4;
    border-radius: 0;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s, color 0.2s;
  }

  .panel-card:hover {
    border-color: #FFB3D9;
    box-shadow: 0 0 12px rgba(255, 105, 180, 0.5);
    color: var(--color-text-primary);
  }

  .panel-card:focus-visible {
    border-color: #FFB3D9;
    color: var(--color-text-primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 105, 180, 0.5);
  }

  .panel-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .panel-name {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ─── 3D wheel mode (.is-wheel added by JS when motion is allowed) ─── */

  .nav-wheel.is-wheel {
    align-items: center;
    perspective: 1200px;
    perspective-origin: 50% 50%;
    overflow: hidden;
    cursor: grab;

    /* ── Card size ──────────────────────────────────────────────────────────
       The front card sits at translateZ(radius), so perspective paints it
       larger than its CSS box by p / (p - radius) — here 1200 / (1200 - 450),
       a factor of 1.6. A 288px card therefore covers 460.8px of screen, which
       overflows every phone (360–430px) and gets cut off by the overflow:hidden
       above. So size the card from the space it has to land in, dividing the
       viewport back through the magnification, and cap it at the original
       288×162 so anything with room to spare is left exactly as it was. */
    --wheel-mag: 1.6;
    --wheel-gutter: 24px; /* total breathing room either side of the card */
    --card-w: min(288px, (100vw - var(--wheel-gutter)) / var(--wheel-mag));
    --card-h: calc(var(--card-w) * 9 / 16);
  }

  .nav-wheel.is-wheel:active {
    cursor: grabbing;
  }

  .nav-wheel.is-wheel .wheel-track {
    transform-style: preserve-3d;
    position: relative;
    /* override stacked-list flex */
    flex-direction: unset;
    gap: 0;
    max-width: unset;
    width: var(--card-w);
    height: var(--card-h);
  }

  /* Shadow footprint — flat pink-tinted ellipse on the floor.
     Position and opacity driven each frame by updateEmphasis(). */
  .nav-wheel.is-wheel .wheel-shadow {
    display: block;
    position: absolute;
    inset: 0;
    width: var(--card-w);
    height: var(--card-h);
    pointer-events: none;
    list-style: none;
    background: radial-gradient(
      ellipse 80% 60% at 50% 50%,
      rgba(255, 105, 180, 0.45),
      transparent 100%
    );
    border-radius: 0;
  }

  .nav-wheel.is-wheel .wheel-panel {
    position: absolute;
    inset: 0;
    backface-visibility: visible;
    width: var(--card-w);
    height: var(--card-h);
  }

  .nav-wheel.is-wheel .panel-card {
    position: relative;
    width: var(--card-w);
    height: var(--card-h);
  }

  /* Image fills the full 16:9 card face */
  .nav-wheel.is-wheel .panel-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: unset;
    flex: unset;
    min-height: unset;
  }

  /* Caption overlays the bottom of the card so the face stays exactly 16:9.
     Colours come from tokens so the caption follows the active theme. */
  .nav-wheel.is-wheel .panel-name {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-sm);
    background: var(--color-caption-bg);
    color: var(--color-caption-text);
    flex-shrink: unset;
  }

  /* ─── Desktop wheel ─── */

  @media (min-width: 768px) {
    .nav-wheel.is-wheel {
      perspective: 1800px;

      /* Fixed 16:9 desktop card: 480×270, exactly as before — laptops are
         left alone. (Magnification here is 1800 / (1800 - 780) = 1.765, so
         the front card paints 847px; a window between 768 and 847px wide
         still clips it. Swap these two lines for the min() form above with
         --wheel-mag: 1.765 if that ever needs fitting too.) */
      --card-w: 480px;
      --card-h: 270px;
    }
  }
</style>
